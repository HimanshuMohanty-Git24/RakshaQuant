# ===========================================
# Agentic Paper Trading System - Environment
# ===========================================

# -----------------------------------------
# LLM Provider - Groq (FREE tier available)
# Get API key: https://console.groq.com/keys
# -----------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# -----------------------------------------
# Broker API - DhanHQ (Sandbox for paper trading)
# 1. Create account: https://dhan.co
# 2. Developer Portal: https://developer.dhan.co
# 3. Sandbox Token: https://developer.dhan.co (use sandbox URL below)
# 4. Production Token: https://web.dhan.co (use api.dhan.co URL)
# -----------------------------------------
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token
# Use sandbox.dhan.co for sandbox tokens, api.dhan.co for production
DHAN_BASE_URL=https://sandbox.dhan.co/v2
# -----------------------------------------
# Observability - LangSmith (FREE tier: 5K traces/month)
# Get API key: https://smith.langchain.com/settings
# -----------------------------------------
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=trading-agent
LANGSMITH_TRACING_V2=true

# -----------------------------------------
# Database - PostgreSQL (FREE cloud options)
# 
# Option 1: Neon (RECOMMENDED - 0.5GB free)
#   https://neon.tech → Create project → Copy connection string
#
# Option 2: Supabase (500MB free)
#   https://supabase.com → New project → Settings > Database > Connection string
#
# Option 3: Railway (500MB free trial)
#   https://railway.app → New project → Add PostgreSQL
# -----------------------------------------
DATABASE_URL=postgresql://user:password@your-db-host.neon.tech/trading_agent?sslmode=require

# Trading Configuration
TRADING_MODE=paper  # paper | live
MAX_DAILY_TRADES=50
MAX_POSITION_SIZE=100000
DAILY_LOSS_LIMIT=10000

# ===========================================
# Free Tier Configuration (NEW)
# ===========================================
# Market data source: yfinance (free) or dhan (requires account)
MARKET_DATA_SOURCE=yfinance

# Execution mode: local_paper (free), dhan_paper (sandbox), or live
EXECUTION_MODE=local_paper

# Enable AI-powered news sentiment analysis
ENABLE_NEWS_ANALYSIS=true

# Starting balance for local paper trading (INR)
PAPER_WALLET_BALANCE=1000000

# Paper trading costs (so paper P&L is net of realistic costs, not fill-at-screen-price).
# Configurable approximations of an NSE discount-broker cost stack; set to 0 for ideal fills.
PAPER_SLIPPAGE_BPS=2.0       # adverse slippage on fills (2 = 0.02%)
PAPER_BROKERAGE_BPS=3.0      # brokerage as bps of notional
PAPER_BROKERAGE_MAX=20.0     # per-order brokerage cap in INR (0 = uncapped)
PAPER_STATUTORY_BPS=5.0      # combined STT + exchange + SEBI + stamp, as bps
PAPER_GST_PCT=18.0           # GST as a percent of brokerage

# Data ingestion / efficiency
# Compute indicators on settled bars only (drop the still-forming current-day bar) to
# avoid intra-bar repainting / look-ahead. Recommended true.
SIGNALS_EXCLUDE_FORMING_BAR=true
# Skip NEW entries when the freshest quote is older than this many seconds (0 = disabled).
# Exits still run on the last known price.
MAX_QUOTE_STALENESS_SECONDS=0

# ===========================================
# Telegram Notifications (Optional)
# ===========================================
# Get bot token: Talk to @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get chat ID: Talk to @userinfobot on Telegram
# TELEGRAM_CHAT_ID=your_chat_id_here

# Enable/disable Telegram notifications
TELEGRAM_ENABLED=true

# ===========================================
# FinOps - LLM cost tracking & budgets (Optional)
# ===========================================
# Track Groq token usage + paid-tier-equivalent cost, and alert on budget breaches.
FINOPS_ENABLED=true

# Daily caps (per IST day, across all agents). 0 = unlimited (free-tier default).
# When a hard cap is hit, the loop pauses NEW agent cycles (exits still run).
DAILY_TOKEN_BUDGET=0
DAILY_COST_BUDGET_USD=0.0

# Soft-alert threshold as a fraction of a budget (0.8 = warn at 80%).
FINOPS_BUDGET_SOFT_PCT=0.8

# ===========================================
# Profit-target goal engine (Optional)
# ===========================================
# Monthly target as a fraction of capital (0.05 = 5%/mo) and/or an INR amount.
# The larger of the two wins. 0/0 = disabled. The engine is advisory only: it never
# changes position sizing or relaxes risk limits — if a target needs more risk than
# allowed it is flagged infeasible and you are told to LOWER the target.
MONTHLY_PROFIT_TARGET_PCT=0.0
MONTHLY_PROFIT_TARGET_AMOUNT=0.0

# Assumptions used to derive the required win-rate / trade-frequency and pace.
TRADING_DAYS_PER_MONTH=21
EXPECTED_TRADES_PER_DAY=5
GOAL_ASSUMED_WIN_RATE=0.5
GOAL_REWARD_RISK_RATIO=1.5
GOAL_OFF_PACE_TOLERANCE=0.2
